  "scripts": {
    "prepare": "node scripts/install-git-hooks.mjs",
    "postinstall": "node scripts/link-skills.mjs",
    "dev:docker": "./docker/dev/rspace-dev",
    "feature-flags:generate": "node scripts/generate-feature-flags.mjs",
    "feature-flags:check": "node scripts/generate-feature-flags.mjs --check",
    "test": "cd src/main/webapp/ui && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" vitest run",
    "test:ui": "cd src/main/webapp/ui && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" vitest --ui",
    "build": "cd src/main/webapp/ui && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" vite build --config vite.config.ts",
    "build:stats": "cd src/main/webapp/ui && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" FRONTEND_BUILD_STATS=true vite build --config vite.config.ts",
    "serve": "cd src/main/webapp/ui && cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" vite --config vite.config.ts",
    "tsc": "cd src/main/webapp/ui && tsc --noEmit",
    "test-browser": "cd src/main/webapp/ui && cross-env vitest run --config vitest.browser.config.ts",
    "test-browser:ui": "cd src/main/webapp/ui && cross-env vitest --config vitest.browser.config.ts --ui --standalone",
    "test-browser:watch": "cd src/main/webapp/ui && cross-env vitest --config vitest.browser.config.ts",
    "lint": "cd src/main/webapp/ui && biome check .",
    "lint:fix": "cd src/main/webapp/ui && biome check --write .",
    "format": "cd src/main/webapp/ui && biome format --write .",
    "lint:ci": "cd src/main/webapp/ui && biome ci --error-on-warnings --diagnostic-level=info .",
    "biome": "cd src/main/webapp/ui && biome",
    "i18n:extract": "cd src/main/webapp/ui && i18next-cli extract",
    "i18n:check": "cd src/main/webapp/ui && i18next-cli extract --ci",
    "i18n:status": "cd src/main/webapp/ui && i18next-cli status",
    "i18n:lint": "cd src/main/webapp/ui && i18next-cli lint",
    "i18n:types": "cd src/main/webapp/ui && i18next-cli types",
    "test-e2e": "cd src/main/webapp/ui && cross-env playwright test --config playwright-e2e.config.ts",
    "test-e2e:ui": "cd src/main/webapp/ui && cross-env playwright test --config playwright-e2e.config.ts --ui --project=chromium",
    "test-e2e:api": "cd src/main/webapp/ui && cross-env playwright test --config playwright-e2e.config.ts --project=api",
    "test-e2e:debug": "cd src/main/webapp/ui && cross-env PW_LOG=trace playwright test --config playwright-e2e.config.ts",
    "storybook": "cd src/main/webapp/ui && storybook dev -p 6006",
    "build-storybook": "cd src/main/webapp/ui && storybook build",
    "test-storybook": "cd src/main/webapp/ui && vitest run --config .storybook/vitest.config.ts"
  },
