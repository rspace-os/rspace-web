#!/usr/bin/env bash
#
# rspace-dev — boot a complete RSpace instance for THIS git worktree, in Docker.
#
# Each worktree gets its own isolated stack: a project name derived from the
# worktree directory, its own database/volumes, and its own set of free host
# ports (recorded in docker/dev/.env). The worktree source tree is bind-mounted
# into the containers, so your edits are live.
#
# Usage:
#   ./docker/dev/rspace-dev <command> [args]
#
# Commands:
#   up [--fresh] [--chemistry|--no-chemistry] [--observability]
#                  Build images (if needed) and start db + app + frontend + Apache.
#                  First boot (or --fresh) recreates the DB schema + sample data.
#                  --chemistry also starts the optional chemistry microservice
#                  (rspaceops/oss-chemistry) and points the app at it; the choice
#                  persists in .env until --no-chemistry.
#                  --observability starts OpenTelemetry and Elastic APM/ELK.
#   down           Stop and remove the containers (keeps the database + caches).
#   reload         Recompile and hot-redeploy the whole webapp (rebuilds the
#                  Spring context) in the same JVM — applies any Java/JSP/config
#                  change without a full JVM restart. (Per-class live reload is
#                  done from your IDE; see README "Hot reloading Java".)
#   restart        Restart the backend (full JVM restart).
#   reset-db       Recreate the database from scratch (drop-recreate-db) and
#                  restart the backend. Destroys local data in this worktree.
#   logs [svc]     Follow logs (default: app). svc = app | frontend | apache | db.
#   ps | status    Show stack status and the URLs/ports for this worktree.
#   shell [svc]    Open a shell in a service container (default: app).
#   db             Open a MariaDB client against this worktree's database.
#   build          Rebuild the app + frontend images.
#   nuke           Stop and remove containers AND this worktree's volumes
#                  (database, node_modules, build output, filestore).
#   compose ...    Run an arbitrary `docker compose` subcommand for this stack.
#
# Shared Maven (.m2) and pnpm caches are reused across worktrees to save
# bandwidth; databases and node_modules are per-worktree.
set -euo pipefail

# --- locate things ----------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.yml"
ENV_FILE="${SCRIPT_DIR}/.env"

# Worktree root (absolute). Falls back to two levels up from docker/dev.
if RSPACE_SRC="$(git -C "${SCRIPT_DIR}" rev-parse --show-toplevel 2>/dev/null)"; then
  :
else
  RSPACE_SRC="$(cd "${SCRIPT_DIR}/../.." && pwd)"
fi

die() { echo "rspace-dev: $*" >&2; exit 1; }

# Project name: rspace-<sanitised worktree dir name>. Keeps Docker objects from
# different worktrees from colliding.
project_name() {
  local base
  base="$(basename "${RSPACE_SRC}")"
  base="$(printf '%s' "${base}" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9_-' '-')"
  base="$(printf '%s' "${base}" | sed -e 's/^[^a-z0-9]*//' -e 's/-*$//')"
  [ -n "${base}" ] || base="worktree"
  printf 'rspace-%s' "${base}"
}

# True if something is already listening on 127.0.0.1:<port>.
port_in_use() {
  local port="$1"
  # bash built-in /dev/tcp connect; success => a listener exists => in use.
  ( exec 3<>"/dev/tcp/127.0.0.1/${port}" ) >/dev/null 2>&1 && return 0 || return 1
}

# Echo the first free port at/after $1, skipping any already recorded in .env.
free_port_from() {
  local candidate="$1"
  local guard=0
  while :; do
    if ! port_in_use "${candidate}" && ! grep -q "=${candidate}\$" "${ENV_FILE}" 2>/dev/null; then
      printf '%s' "${candidate}"
      return 0
    fi
    candidate=$((candidate + 1))
    guard=$((guard + 1))
    [ "${guard}" -lt 500 ] || die "could not find a free port near $1"
  done
}

# Deterministic base offset from the worktree path, so a given worktree tends to
# keep the same ports across runs even before .env exists.
path_offset() {
  local sum
  sum="$(printf '%s' "${RSPACE_SRC}" | cksum | awk '{print $1}')"
  printf '%s' "$((sum % 200))"
}

ensure_env() {
  if [ -f "${ENV_FILE}" ]; then
    return 0
  fi
  echo "rspace-dev: first run for this worktree — allocating ports ..." >&2
  local offset app_port vite_port db_port debug_port polling
  offset="$(path_offset)"
  app_port="$(free_port_from "$((8080 + offset))")"
  vite_port="$(free_port_from "$((5173 + offset))")"
  db_port="$(free_port_from "$((3306 + offset))")"
  debug_port="$(free_port_from "$((5005 + offset))")"
  # File-watch polling is needed where inotify events do not reach the container
  # (macOS/Windows Docker Desktop VMs) but burns CPU needlessly on native Linux
  # Docker, where events are delivered. WSL2 reports Linux and gets events when
  # the repo is on the Linux filesystem (as our docs require). Override in .env.
  case "$(uname -s)" in
    Linux) polling=false ;;
    *)     polling=true ;;
  esac
  cat > "${ENV_FILE}" <<EOF
# Generated by rspace-dev for worktree: ${RSPACE_SRC}
# Delete this file to re-allocate ports.
COMPOSE_PROJECT_NAME=$(project_name)
RSPACE_SRC="${RSPACE_SRC}"
APP_PORT=${app_port}
VITE_PORT=${vite_port}
DB_PORT=${db_port}
DEBUG_PORT=${debug_port}
VITE_HMR_HOST=localhost
VITE_USE_POLLING=${polling}
EOF
  ensure_observability_ports
  echo "rspace-dev: wrote ${ENV_FILE} (app=${app_port}, vite=${vite_port}, db=${db_port}, debug=${debug_port})" >&2
}

ensure_env_port() {
  local key="$1" first_port="$2"
  if ! grep -q "^${key}=" "${ENV_FILE}" 2>/dev/null; then
    printf '%s=%s\n' "${key}" "$(free_port_from "${first_port}")" >> "${ENV_FILE}"
  fi
}

ensure_observability_ports() {
  local offset
  offset="$(path_offset)"
  ensure_env_port KIBANA_PORT "$((5601 + offset))"
  ensure_env_port ES_PORT "$((9200 + offset))"
  ensure_env_port OTLP_GRPC_PORT "$((4317 + offset))"
  ensure_env_port OTLP_HTTP_PORT "$((4318 + offset))"
}

observability_enabled() {
  [ "$(env_get RSPACE_OBSERVABILITY)" = "true" ]
}

# Read a value out of .env.
env_get() { grep -E "^$1=" "${ENV_FILE}" 2>/dev/null | head -n1 | cut -d= -f2-; }

compose() {
  ensure_env
  local profile_args=()
  [ "$(env_get RSPACE_CHEMISTRY)" = "true" ] && profile_args+=(--profile chemistry)
  if observability_enabled; then
    profile_args+=(--profile observability)
  fi
  docker compose \
    --project-directory "${SCRIPT_DIR}" \
    --env-file "${ENV_FILE}" \
    -f "${COMPOSE_FILE}" \
    ${profile_args[@]+"${profile_args[@]}"} \
    "$@"
}

# Include disabled profiles during teardown.
compose_all_profiles() {
  ensure_env
  docker compose \
    --project-directory "${SCRIPT_DIR}" \
    --env-file "${ENV_FILE}" \
    -f "${COMPOSE_FILE}" \
    --profile chemistry \
    --profile observability \
    "$@"
}

# Persist a key=value into .env (replace existing line or append).
env_set() {
  local key="$1" value="$2"
  if grep -qE "^${key}=" "${ENV_FILE}" 2>/dev/null; then
    sed -i.bak "s|^${key}=.*|${key}=${value}|" "${ENV_FILE}" && rm -f "${ENV_FILE}.bak"
  else
    printf '%s=%s\n' "${key}" "${value}" >> "${ENV_FILE}"
  fi
}

# True once this worktree's database volume exists (i.e. not a first boot).
db_volume_exists() {
  local proj
  proj="$(env_get COMPOSE_PROJECT_NAME)"
  [ -n "$(docker volume ls -q -f "name=^${proj}_db-data\$" 2>/dev/null)" ]
}

print_urls() {
  local app_port vite_port db_port debug_port chem
  app_port="$(env_get APP_PORT)"; vite_port="$(env_get VITE_PORT)"; db_port="$(env_get DB_PORT)"
  debug_port="$(env_get DEBUG_PORT)"
  chem="off (enable with: up --chemistry)"
  [ "$(env_get RSPACE_CHEMISTRY)" = "true" ] && chem="on (http://chemistry:8090, internal)"
  cat <<EOF

  RSpace (this worktree: $(basename "${RSPACE_SRC}"))
    App        http://localhost:${app_port}
    Vite (HMR) http://localhost:${vite_port}
    Database   127.0.0.1:${db_port}  (db=rspace user=rspacedbuser pass=rspacedbpwd)
    Debug      127.0.0.1:${debug_port:-5005}  (JDWP — attach IntelliJ "Remote JVM Debug")
    Chemistry  ${chem}
EOF
  if observability_enabled; then
    cat <<EOF

  Observability
    APM UI         http://localhost:$(env_get KIBANA_PORT)/app/apm
    Kibana         http://localhost:$(env_get KIBANA_PORT)
    Elasticsearch  http://localhost:$(env_get ES_PORT)
    Collector      OTLP gRPC 127.0.0.1:$(env_get OTLP_GRPC_PORT) · OTLP HTTP 127.0.0.1:$(env_get OTLP_HTTP_PORT)
EOF
  else
    cat <<EOF
    Telemetry  off — enable with: ${0##*/} up --observability
EOF
  fi
  cat <<EOF

    Logins: user1a .. user8h / user1234   sysadmin1 / sysWisc23!
EOF
}

# The Maven (.m2) and pnpm caches are shared across worktrees and declared
# `external` in the compose file (so `nuke` can't delete them). external volumes
# are not auto-created, so create them here (idempotent).
ensure_shared_volumes() {
  docker volume create rspace-dev-m2-repo >/dev/null
  docker volume create rspace-dev-pnpm-store >/dev/null
}

cmd_up() {
  ensure_env
  ensure_shared_volumes
  # Backfill DEBUG_PORT for .env files created before debug support was added.
  if ! grep -q '^DEBUG_PORT=' "${ENV_FILE}" 2>/dev/null; then
    local dbg
    dbg="$(free_port_from "$((5005 + $(path_offset)))")"
    printf 'DEBUG_PORT=%s\n' "${dbg}" >> "${ENV_FILE}"
    echo "rspace-dev: allocated debug port ${dbg}" >&2
  fi
  ensure_observability_ports
  local fresh="false"
  local arg
  for arg in "$@"; do
    case "${arg}" in
      --fresh)        fresh="true" ;;
      --chemistry)    env_set RSPACE_CHEMISTRY true
                      echo "rspace-dev: chemistry service enabled (persisted in .env)" >&2 ;;
      --no-chemistry) env_set RSPACE_CHEMISTRY false
                      # A profile-disabled service is invisible to later compose
                      # commands, so stop a leftover container explicitly.
                      docker rm -f "$(env_get COMPOSE_PROJECT_NAME)-chemistry" >/dev/null 2>&1 || true
                      echo "rspace-dev: chemistry service disabled (persisted in .env)" >&2 ;;
      --observability)
        env_set RSPACE_OBSERVABILITY true
        echo "rspace-dev: observability enabled (OTel collector + Elasticsearch + Kibana)" >&2
        ;;
      *) die "unknown 'up' option '${arg}' (supported: --fresh, --chemistry, --no-chemistry, --observability)" ;;
    esac
  done

  if [ "${fresh}" = "true" ] || ! db_volume_exists; then
    echo "rspace-dev: initialising database (drop-recreate-db) — this first boot is slower." >&2
    export RSPACE_DB_MODE="drop-recreate-db"
  else
    export RSPACE_DB_MODE="keepdbintact"
  fi

  # The app shares the frontend's network namespace (network_mode in the compose
  # file). If `up` recreates the frontend, the app's reference to the old
  # namespace goes stale, so it must be recreated too. Apache is also recreated
  # so it resolves the frontend service's new address.
  local proj fe_before fe_after
  proj="$(env_get COMPOSE_PROJECT_NAME)"
  fe_before="$(docker ps -aq -f "name=^${proj}-frontend$" 2>/dev/null)"
  compose up -d --build
  fe_after="$(docker ps -aq -f "name=^${proj}-frontend$" 2>/dev/null)"
  if [ -n "${fe_before}" ] && [ "${fe_before}" != "${fe_after}" ]; then
    echo "rspace-dev: frontend was recreated — rebinding app and Apache ..." >&2
    compose up -d --force-recreate app apache
  fi

  print_urls
  echo
  echo "  Tail backend startup with:  ${0##*/} logs app"
  echo "  (the backend takes a few minutes to compile + start on first boot)"
}

cmd_down()    { compose_all_profiles down; }
cmd_build()   { compose build; }
cmd_ps()      { compose ps; print_urls; }
cmd_logs()    { compose logs -f "${1:-app}"; }
# NOT `compose restart`: that restarts the SAME container with the env baked in
# at creation time, so a container created by the first `up` / `reset-db` (which
# set RSPACE_DB_MODE=drop-recreate-db) would replay the drop and WIPE the schema
# on every restart. Force-recreate with keepdbintact instead — this also re-reads
# the launcher env and .env (so debug/hotswap/etc. knobs set in .env take effect).
cmd_restart() {
  db_volume_exists || die "no database for this worktree yet — run '${0##*/} up' first"
  RSPACE_DB_MODE="keepdbintact" compose up -d --force-recreate app apache
}

cmd_reload() {
  echo "rspace-dev: recompiling changed Java ..."
  # Compile offline first (fast). Retry online ONLY when the failure looks like
  # a missing dependency — a genuine compile error would otherwise be shown
  # twice (offline, then again online) before failing.
  compose exec -T app sh -c '
    mvn -B -q -o compile > /tmp/rspace-compile.log 2>&1 && exit 0
    if grep -qiE "offline mode|Cannot access .* in offline|dependencies could not be resolved" /tmp/rspace-compile.log; then
      mvn -B -q compile
    else
      cat /tmp/rspace-compile.log
      exit 1
    fi
  '
  echo "rspace-dev: triggering Jetty hot redeploy (full Spring context rebuild) ..."
  compose exec -T app sh -c 'printf "\n" > /tmp/jetty.in'
  echo "rspace-dev: redeploy signalled — watch '${0##*/} logs app'."
}

cmd_reset_db() {
  echo "rspace-dev: recreating the database from scratch for this worktree ..."
  # No --no-deps: the app shares the frontend's network namespace, so Compose
  # must be able to start frontend (and db) if the stack is currently down.
  RSPACE_DB_MODE="drop-recreate-db" compose up -d --force-recreate app apache
  print_urls
}

cmd_shell() {
  local svc="${1:-app}"
  compose exec "${svc}" bash 2>/dev/null || compose exec "${svc}" sh
}

cmd_db() {
  # Honour DB_USER / DB_PASSWORD overrides from .env (the compose file already
  # does); fall back to the stock dev credentials.
  local db_user db_pass
  db_user="$(env_get DB_USER)"; db_user="${db_user:-rspacedbuser}"
  db_pass="$(env_get DB_PASSWORD)"; db_pass="${db_pass:-rspacedbpwd}"
  compose exec db mariadb -u"${db_user}" -p"${db_pass}" rspace
}

cmd_nuke() {
  echo "rspace-dev: removing containers AND volumes for this worktree ..." >&2
  compose_all_profiles down -v
}

main() {
  local command="${1:-}"
  [ $# -gt 0 ] && shift || true
  case "${command}" in
    up)               cmd_up "$@" ;;
    down)             cmd_down "$@" ;;
    restart)          cmd_restart "$@" ;;
    reload)           cmd_reload "$@" ;;
    reset-db)         cmd_reset_db "$@" ;;
    logs)             cmd_logs "$@" ;;
    ps|status)        cmd_ps "$@" ;;
    shell|sh)         cmd_shell "$@" ;;
    db)               cmd_db "$@" ;;
    build)            cmd_build "$@" ;;
    nuke)             cmd_nuke "$@" ;;
    compose)          compose "$@" ;;
    ""|-h|--help|help)
      # Print the contiguous header comment block (skip the shebang, stop at the
      # first non-comment line) so help stays correct if the block changes size.
      awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "${BASH_SOURCE[0]}" ;;
    *)
      die "unknown command '${command}' (try: ${0##*/} help)" ;;
  esac
}

if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  main "$@"
fi
