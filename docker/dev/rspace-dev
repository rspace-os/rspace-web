#!/usr/bin/env bash
#
# rspace-dev — boot a complete RSpace instance for THIS git worktree, in Docker.
#
# Each worktree gets its own isolated stack: a project name derived from the
# worktree directory, its own database/volumes, and its own set of free host
# ports (recorded in docker/dev/.env). The worktree source tree is bind-mounted
# into the containers, so your edits are live.
#
# Usage:
#   ./docker/dev/rspace-dev <command> [args]
#
# Commands:
#   up [--fresh]   Build images (if needed) and start db + app + frontend.
#                  First boot (or --fresh) recreates the DB schema + sample data.
#   down           Stop and remove the containers (keeps the database + caches).
#   restart        Restart the backend (full JVM restart; picks up Java changes
#                  after `reload` or after compiling).
#   reload         Recompile changed Java and hot-redeploy the webapp WITHOUT a
#                  JVM restart (faster than `restart`). Frontend changes hot-
#                  reload automatically and need neither.
#   reset-db       Recreate the database from scratch (drop-recreate-db) and
#                  restart the backend. Destroys local data in this worktree.
#   logs [svc]     Follow logs (default: app). svc = app | frontend | db.
#   ps | status    Show stack status and the URLs/ports for this worktree.
#   shell [svc]    Open a shell in a service container (default: app).
#   db             Open a MariaDB client against this worktree's database.
#   build          Rebuild the app + frontend images.
#   nuke           Stop and remove containers AND this worktree's volumes
#                  (database, node_modules, build output, filestore).
#   compose ...    Run an arbitrary `docker compose` subcommand for this stack.
#
# Shared Maven (.m2) and pnpm caches are reused across worktrees to save
# bandwidth; databases and node_modules are per-worktree.
set -euo pipefail

# --- locate things ----------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="${SCRIPT_DIR}/docker-compose.yml"
ENV_FILE="${SCRIPT_DIR}/.env"

# Worktree root (absolute). Falls back to two levels up from docker/dev.
if RSPACE_SRC="$(git -C "${SCRIPT_DIR}" rev-parse --show-toplevel 2>/dev/null)"; then
  :
else
  RSPACE_SRC="$(cd "${SCRIPT_DIR}/../.." && pwd)"
fi

die() { echo "rspace-dev: $*" >&2; exit 1; }

# Project name: rspace-<sanitised worktree dir name>. Keeps Docker objects from
# different worktrees from colliding.
project_name() {
  local base
  base="$(basename "${RSPACE_SRC}")"
  base="$(printf '%s' "${base}" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9_-' '-')"
  base="$(printf '%s' "${base}" | sed -e 's/^[^a-z0-9]*//' -e 's/-*$//')"
  [ -n "${base}" ] || base="worktree"
  printf 'rspace-%s' "${base}"
}

# True if something is already listening on 127.0.0.1:<port>.
port_in_use() {
  local port="$1"
  # bash built-in /dev/tcp connect; success => a listener exists => in use.
  ( exec 3<>"/dev/tcp/127.0.0.1/${port}" ) >/dev/null 2>&1 && return 0 || return 1
}

# Echo the first free port at/after $1, skipping any already recorded in .env.
free_port_from() {
  local candidate="$1"
  local guard=0
  while :; do
    if ! port_in_use "${candidate}" && ! grep -q "=${candidate}\$" "${ENV_FILE}" 2>/dev/null; then
      printf '%s' "${candidate}"
      return 0
    fi
    candidate=$((candidate + 1))
    guard=$((guard + 1))
    [ "${guard}" -lt 500 ] || die "could not find a free port near $1"
  done
}

# Deterministic base offset from the worktree path, so a given worktree tends to
# keep the same ports across runs even before .env exists.
path_offset() {
  local sum
  sum="$(printf '%s' "${RSPACE_SRC}" | cksum | awk '{print $1}')"
  printf '%s' "$((sum % 200))"
}

ensure_env() {
  if [ -f "${ENV_FILE}" ]; then
    return 0
  fi
  echo "rspace-dev: first run for this worktree — allocating ports ..." >&2
  local offset app_port vite_port db_port
  offset="$(path_offset)"
  app_port="$(free_port_from "$((8080 + offset))")"
  vite_port="$(free_port_from "$((5173 + offset))")"
  db_port="$(free_port_from "$((3306 + offset))")"
  cat > "${ENV_FILE}" <<EOF
# Generated by rspace-dev for worktree: ${RSPACE_SRC}
# Delete this file to re-allocate ports.
COMPOSE_PROJECT_NAME=$(project_name)
RSPACE_SRC=${RSPACE_SRC}
APP_PORT=${app_port}
VITE_PORT=${vite_port}
DB_PORT=${db_port}
VITE_HMR_HOST=localhost
VITE_USE_POLLING=true
EOF
  echo "rspace-dev: wrote ${ENV_FILE} (app=${app_port}, vite=${vite_port}, db=${db_port})" >&2
}

# Read a value out of .env.
env_get() { grep -E "^$1=" "${ENV_FILE}" 2>/dev/null | head -n1 | cut -d= -f2-; }

compose() {
  ensure_env
  docker compose \
    --project-directory "${SCRIPT_DIR}" \
    --env-file "${ENV_FILE}" \
    -f "${COMPOSE_FILE}" \
    "$@"
}

# True once this worktree's database volume exists (i.e. not a first boot).
db_volume_exists() {
  local proj
  proj="$(env_get COMPOSE_PROJECT_NAME)"
  [ -n "$(docker volume ls -q -f "name=^${proj}_db-data\$" 2>/dev/null)" ]
}

print_urls() {
  local app_port vite_port db_port
  app_port="$(env_get APP_PORT)"; vite_port="$(env_get VITE_PORT)"; db_port="$(env_get DB_PORT)"
  cat <<EOF

  RSpace (this worktree: $(basename "${RSPACE_SRC}"))
    App        http://localhost:${app_port}
    Vite (HMR) http://localhost:${vite_port}
    Database   127.0.0.1:${db_port}  (db=rspace user=rspacedbuser pass=rspacedbpwd)

    Logins: user1a .. user8h / user1234   sysadmin1 / sysWisc23!
EOF
}

# The Maven (.m2) and pnpm caches are shared across worktrees and declared
# `external` in the compose file (so `nuke` can't delete them). external volumes
# are not auto-created, so create them here (idempotent).
ensure_shared_volumes() {
  docker volume create rspace-dev-m2-repo >/dev/null
  docker volume create rspace-dev-pnpm-store >/dev/null
}

cmd_up() {
  ensure_env
  ensure_shared_volumes
  local fresh="false"
  [ "${1:-}" = "--fresh" ] && fresh="true"

  if [ "${fresh}" = "true" ] || ! db_volume_exists; then
    echo "rspace-dev: initialising database (drop-recreate-db) — this first boot is slower." >&2
    export RSPACE_DB_MODE="drop-recreate-db"
  else
    export RSPACE_DB_MODE="keepdbintact"
  fi

  # The app shares the frontend's network namespace (network_mode in the compose
  # file). If `up` recreates the frontend, the app's reference to the old
  # namespace goes stale, so it must be recreated too. Detect a frontend
  # container-id change across `up` and rebind the app when needed.
  local proj fe_before fe_after
  proj="$(env_get COMPOSE_PROJECT_NAME)"
  fe_before="$(docker ps -aq -f "name=^${proj}-frontend$" 2>/dev/null)"
  compose up -d --build
  fe_after="$(docker ps -aq -f "name=^${proj}-frontend$" 2>/dev/null)"
  if [ -n "${fe_before}" ] && [ "${fe_before}" != "${fe_after}" ]; then
    echo "rspace-dev: frontend was recreated — rebinding the app to its network ..." >&2
    compose up -d --force-recreate app
  fi

  print_urls
  echo
  echo "  Tail backend startup with:  ${0##*/} logs app"
  echo "  (the backend takes a few minutes to compile + start on first boot)"
}

cmd_down()    { compose down; }
cmd_build()   { compose build; }
cmd_ps()      { compose ps; print_urls; }
cmd_logs()    { compose logs -f "${1:-app}"; }
cmd_restart() { compose restart app; }

cmd_reload() {
  echo "rspace-dev: recompiling changed Java ..."
  compose exec -T app mvn -B -q -o compile \
    || compose exec -T app mvn -B -q compile
  echo "rspace-dev: triggering Jetty hot redeploy ..."
  compose exec -T app sh -c 'printf "\n" > /tmp/jetty.in'
  echo "rspace-dev: redeploy signalled — watch '${0##*/} logs app'."
}

cmd_reset_db() {
  echo "rspace-dev: recreating the database from scratch for this worktree ..."
  RSPACE_DB_MODE="drop-recreate-db" compose up -d --force-recreate --no-deps app
  print_urls
}

cmd_shell() {
  local svc="${1:-app}"
  compose exec "${svc}" bash 2>/dev/null || compose exec "${svc}" sh
}

cmd_db() {
  compose exec db mariadb -urspacedbuser -prspacedbpwd rspace
}

cmd_nuke() {
  echo "rspace-dev: removing containers AND volumes for this worktree ..." >&2
  compose down -v
}

main() {
  local command="${1:-}"
  [ $# -gt 0 ] && shift || true
  case "${command}" in
    up)               cmd_up "$@" ;;
    down)             cmd_down "$@" ;;
    restart)          cmd_restart "$@" ;;
    reload)           cmd_reload "$@" ;;
    reset-db)         cmd_reset_db "$@" ;;
    logs)             cmd_logs "$@" ;;
    ps|status)        cmd_ps "$@" ;;
    shell|sh)         cmd_shell "$@" ;;
    db)               cmd_db "$@" ;;
    build)            cmd_build "$@" ;;
    nuke)             cmd_nuke "$@" ;;
    compose)          compose "$@" ;;
    ""|-h|--help|help)
      # Print the contiguous header comment block (skip the shebang, stop at the
      # first non-comment line) so help stays correct if the block changes size.
      awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "${BASH_SOURCE[0]}" ;;
    *)
      die "unknown command '${command}' (try: ${0##*/} help)" ;;
  esac
}

main "$@"
