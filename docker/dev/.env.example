# Example environment for the Docker dev stack.
#
# You normally do NOT create this file by hand — `./rspace-dev up` generates a
# per-worktree `.env` with free ports the first time you run it. Copy this file
# to `.env` only if you want to pin specific values.

# Compose project name (namespaces containers/volumes for this worktree).
COMPOSE_PROJECT_NAME=rspace-myworktree

# Absolute path to the worktree root that gets bind-mounted into the containers.
RSPACE_SRC=/absolute/path/to/your/worktree

# Host ports (bound to 127.0.0.1 only). Pick values that are free on your host
# and unique per concurrently-running worktree.
APP_PORT=8080
VITE_PORT=5173
DB_PORT=3306
# JDWP remote-debug port (attach IntelliJ "Remote JVM Debug" here).
DEBUG_PORT=5005
# E2E integration mock server, allocated per worktree.
E2E_MOCK_PORT=9099

# Browser-facing HMR host. Keep `localhost`; the Vite server still binds 0.0.0.0
# inside the container so the app container can proxy to it.
VITE_HMR_HOST=localhost

# Poll the filesystem for changes. Needed on macOS/Windows Docker Desktop
# (native fs events don't reach the container); wasteful on native Linux, where
# events are delivered. The launcher picks the right default per platform.
VITE_USE_POLLING=true

# Optional chemistry microservice (rspaceops/oss-chemistry). Normally toggled
# via `rspace-dev up --chemistry` / `--no-chemistry`, which persist this flag.
# RSPACE_CHEMISTRY=true

# Start the local integration mock server and point the backend integrations at
# it. Normally toggled with `rspace-dev up --e2e` / `--no-e2e`.
# RSPACE_E2E_MOCKS=true

# --- Optional overrides ------------------------------------------------------
# DB_IMAGE=mariadb:12.3
# MAVEN_IMAGE=maven:3.9-eclipse-temurin-17
# NODE_IMAGE=node:24-bookworm-slim
# CHEMISTRY_IMAGE=rspaceops/oss-chemistry:latest
# MAVEN_OPTS=-Xmx2g
# RSPACE_DEBUG=false        # disable the JDWP remote-debug agent (on by default)
# RSPACE_DEBUG_SUSPEND=y    # pause JVM startup until a debugger attaches
# RSPACE_HOTSWAP=false      # disable JBR enhanced redefinition + HotswapAgent
# RSPACE_LEGACY_ASSET_CACHE_BUSTING=false  # drop ?v= on legacy assets in dev
# RSPACE_INDEX_ON_STARTUP=true             # rebuild the Lucene index on boot
# RSPACE_SESSION_COOKIE_NAME=JSESSIONID_mybranch  # pin the session cookie name
#                           # (defaults to JSESSIONID_<APP_PORT>, unique per
#                           # worktree so localhost instances don't log each
#                           # other out)
