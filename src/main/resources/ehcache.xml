<?xml version="1.0" encoding="UTF-8"?>
<config xmlns="http://www.ehcache.org/v3"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.ehcache.org/v3 http://www.ehcache.org/schema/ehcache-core-3.0.xsd">

  <cache alias="com.researchspace.model.Role">
    <expiry>
      <none/>
    </expiry>
    <resources>
      <heap unit="entries">100</heap>
    </resources>
  </cache>

  <cache alias="com.researchspace.model.Role.permissionStrings">
    <expiry>
      <none/>
    </expiry>
    <resources>
      <heap unit="entries">100</heap>
    </resources>
  </cache>

  <cache alias="com.researchspace.model.UserGroup">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
      <heap unit="entries">1000</heap>
    </resources>
  </cache>

  <cache alias="com.researchspace.model.User">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
      <heap unit="entries">1000</heap>
    </resources>
  </cache>

  <!--
    Hibernate 6 requires @Cache to be declared on the root entity of an inheritance
    hierarchy, so it was moved from User onto AbstractUserOrGroupImpl (the
    TABLE_PER_CLASS root of User and Group). The whole hierarchy is therefore cached
    in a single region named after the root entity. Sizing matches the legacy User
    region; the heap is bumped from 1000 to 1500 because Group entities now share this
    region with User (both draw ids from the same uog_gen sequence, so keys never
    collide). The com.researchspace.model.User region above is now unused for the
    entity itself but its collection regions (.roles / .fullName) remain in use.
  -->
  <cache alias="com.researchspace.model.AbstractUserOrGroupImpl">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
      <heap unit="entries">1500</heap>
    </resources>
  </cache>

  <cache alias="pubchemResults">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
      <heap unit="entries">500</heap>
    </resources>
  </cache>

  <cache alias="com.researchspace.model.User.roles">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
      <heap unit="entries">1000</heap>
    </resources>
  </cache>

  <cache alias="com.researchspace.model.User.fullName">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
