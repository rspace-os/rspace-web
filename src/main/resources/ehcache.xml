    </expiry>
    <resources>
      <heap unit="entries">1000</heap>
    </resources>
  </cache>

  <!--
    Hibernate 6 requires @Cache on the root entity of an inheritance hierarchy, so it
    was moved from RSForm onto AbstractForm (the SINGLE_TABLE root of the form
    hierarchy). The whole hierarchy is cached in a single region named after the root
    entity, so this region is renamed from com.researchspace.model.record.RSForm to
    com.researchspace.model.record.AbstractForm. Sizing is unchanged from the legacy
    RSForm region. (Same pattern as the User -> AbstractUserOrGroupImpl move above.)
  -->
  <cache alias="com.researchspace.model.record.AbstractForm">
