    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
      <heap unit="entries">10000</heap>
    </resources>
  </cache>

  <!--
    No key-type/value-type: Hibernate 6 L2 entity keys are BasicCacheKeyImplementation
    (not java.lang.Long), so a typed region throws ClassCastException at runtime.
    EhcacheL2RuntimeTest guards that these regions accept composite keys.
  -->
  <cache alias="com.researchspace.model.ImageBlob">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
      <heap unit="entries">1000</heap>
