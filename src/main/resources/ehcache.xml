  </cache>

  <!--
    Entity regions for @Cache-annotated entities that previously had no explicit region.
    Under Hibernate 6 create-warn these were silently given untuned default regions, losing
    the legacy defaultCache template behaviour. Added with conservative sizing during the
    Spring 6 migration. EhcacheRegionConfigTest guards that every @Cache entity has a region
    here.
  -->
  <cache alias="com.researchspace.model.UserApiKey">
    <expiry>
      <ttl unit="seconds">3600</ttl>
    </expiry>
    <resources>
