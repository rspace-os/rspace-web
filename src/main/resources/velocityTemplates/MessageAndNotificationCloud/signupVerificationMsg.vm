#*
Template for messaging a user that signed up on cloud without using verification link
Arguments:

- verifyLink - The  URL to verify signup
- ipAddress - The IP address from where the request was generated.
*#

<p>$msg.format("email.common.greeting", [${firstName}])</p>

<p>$msg.getMessage("email.cloud.signupVerification.signedUp")</p>
<p>
${htmlDomainPrefix}
</p>

<p>$msg.getMessage("email.cloud.signupVerification.activate")</p>

<p>
<a href="${verifyLink}">${verifyLink}</a>
</p>

<p>
$msg.getMessage("email.common.dontReply")
</p><p/>

$msg.getMessage("email.common.signatureSignOff")
<p>
$msg.getMessage("email.common.signatureTeam")
</p>
<p/>
<div style="font-size:80%">
$msg.format("email.common.sourceIpFooter", [$ipAddress, "https://ip-lookup.net/index.php?ip=$ipAddress"])
</div>
