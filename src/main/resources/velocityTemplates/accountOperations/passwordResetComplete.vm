#*
Template for messaging a user that their username/password was reset.
Arguments:
- passwordType - "password" or "verification password".
- msg - MessageSourceUtils for i18n phrase lookup
*#
<p>$msg.getMessage("email.common.greetingDefault")</p>

<p>
$msg.format("email.account.passwordResetComplete.body", [${passwordType}])
</p>

<p>
$msg.format("email.account.passwordResetComplete.ifNotYou", [${passwordType}])
</p>

<p><p>
$msg.getMessage("email.common.dontReply")
</p></p>
