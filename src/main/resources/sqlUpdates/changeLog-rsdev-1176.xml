<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd">

    <changeSet id="2026-06-25a" context="run" author="nico">
        <comment>Add four system settings for configuring PIDINST B2INST instrument PID registration (RSDEV-1176).
            B2INST reuses the IdentifierSettings shape: username carries pidinst.b2inst.community.id and
            password carries pidinst.b2inst.token; there is no real username or repositoryPrefix.</comment>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pidinst.b2inst.enabled"/>
            <column name="type" type="NUMERIC" value="0"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pidinst.b2inst.enabled')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value="false"/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pidinst.b2inst.enabled')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pidinst.b2inst.server.url"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pidinst.b2inst.server.url')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value=""/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pidinst.b2inst.server.url')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pidinst.b2inst.community.id"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pidinst.b2inst.community.id')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value=""/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pidinst.b2inst.community.id')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pidinst.b2inst.token"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pidinst.b2inst.token')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value=""/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pidinst.b2inst.token')"/>
        </insert>
    </changeSet>

</databaseChangeLog>
