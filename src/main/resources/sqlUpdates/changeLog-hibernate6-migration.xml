<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="hibernate6-rename-sequence-column" author="spring6-migration">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="hibernate_sequences" columnName="sequence_next_hi_value"/>
        </preConditions>
        <comment>Rename hibernate_sequences value column to match Hibernate 6 default TABLE generator expectations</comment>
        <renameColumn tableName="hibernate_sequences"
                      oldColumnName="sequence_next_hi_value"
                      newColumnName="next_val"
                      columnDataType="int"/>
    </changeSet>
    <changeSet id="appconfigelementset-natural-id" author="spring6-migration">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="AppConfigElementSet" columnName="naturalId"/></not>
        </preConditions>
        <comment>Add stable UUID natural key for AppConfigElementSet so equals/hashCode are safe before and after persist.
            Column is added nullable and non-unique first, then populated, then constrained: adding it as
            NOT NULL UNIQUE up front fails on a populated table because every existing row is back-filled with
            the empty-string default, colliding on the unique index before the UPDATE can run.</comment>
        <addColumn tableName="AppConfigElementSet">
            <column name="naturalId" type="varchar(36)"/>
        </addColumn>
        <update tableName="AppConfigElementSet">
            <column name="naturalId" valueComputed="UUID()"/>
            <where>naturalId IS NULL OR naturalId = ''</where>
        </update>
        <addNotNullConstraint tableName="AppConfigElementSet" columnName="naturalId" columnDataType="varchar(36)"/>
        <addUniqueConstraint tableName="AppConfigElementSet" columnNames="naturalId"
                             constraintName="uc_appconfigelementset_naturalid"/>
    </changeSet>

    <changeSet id="externalworkflowdata-enum-ordinal-to-string" author="spring6-migration">
        <comment>Convert ExternalWorkFlowData enum columns from ordinal (integer-as-string) to enum name strings for Hibernate 6 compatibility</comment>
        <update tableName="ExternalWorkFlowData">
            <column name="externalService" value="GALAXY"/>
            <where>externalService = '0'</where>
        </update>
        <update tableName="ExternalWorkFlowData">
            <column name="rspaceDataType" value="LOCAL"/>
            <where>rspaceDataType = '0'</where>
        </update>
        <update tableName="ExternalWorkFlowData">
            <column name="rspaceDataType" value="EXTERNAL"/>
            <where>rspaceDataType = '1'</where>
        </update>
        <update tableName="ExternalWorkFlowData">
            <column name="rspaceContainerType" value="DOCUMENT"/>
            <where>rspaceContainerType = '0'</where>
        </update>
        <update tableName="ExternalWorkFlowData">
            <column name="rspaceContainerType" value="FIELD"/>
            <where>rspaceContainerType = '1'</where>
        </update>
    </changeSet>

</databaseChangeLog>
