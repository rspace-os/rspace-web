<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd">

    <changeSet id="RSDEV-1135-drop-removed-user-profile-fields" context="run" author="copilot">
        <comment>Drop user profile fields that are no longer displayed or editable.</comment>
        <dropColumn tableName="UserProfile" columnName="externalLinkDisplay"/>
        <dropColumn tableName="UserProfile" columnName="externalLinkURL"/>
        <dropColumn tableName="UserProfile" columnName="profileText"/>
    </changeSet>
</databaseChangeLog>
