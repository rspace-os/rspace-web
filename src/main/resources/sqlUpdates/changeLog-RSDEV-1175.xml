<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd">

    <changeSet id="2026-06-12a" context="run,dev-test" author="nico">
        <comment>Add six system settings for configuring PIDINST (instrument PID) registration (RSDEV-1175)</comment>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pdinst.provider"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pdinst.provider')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value="DATACITE_PDINST"/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pdinst.provider')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pdinst.enabled"/>
            <column name="type" type="NUMERIC" value="0"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pdinst.enabled')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value="false"/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pdinst.enabled')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pdinst.server.url"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pdinst.server.url')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value="https://api.datacite.org"/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pdinst.server.url')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pdinst.username"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pdinst.username')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value=""/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pdinst.username')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pdinst.password"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pdinst.password')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value=""/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pdinst.password')"/>
        </insert>

        <insert tableName="PropertyDescriptor">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="defaultValue" type="STRING" value=""/>
            <column name="name" type="STRING" value="pdinst.repositoryPrefix"/>
            <column name="type" type="NUMERIC" value="2"/>
        </insert>
        <insert tableName="SystemProperty">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="dependent_id" type="NUMERIC" value="NULL"/>
            <column name="descriptor_id" type="NUMERIC" valueComputed="(select id from PropertyDescriptor where name ='pdinst.repositoryPrefix')"/>
        </insert>
        <insert tableName="SystemPropertyValue">
            <column name="id" type="NUMERIC" value="NULL"/>
            <column name="value" type="String" value=""/>
            <column name="property_id" type="NUMERIC"
                    valueComputed="(select sp.id from SystemProperty sp inner join PropertyDescriptor pd on sp.descriptor_id=pd.id where pd.name='pdinst.repositoryPrefix')"/>
        </insert>
    </changeSet>

</databaseChangeLog>
