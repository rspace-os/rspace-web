{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "target": "ES2024",
    "jsx": "react-jsx",
    "allowJs": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    // These expose widespread pre-existing array-index and optional-property typing errors;
    // migrate those incrementally before enabling the checks (RSDEV-1242).
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["@vitest/browser/matchers", "@sa11y/vitest", "jquery", "vite/client"]
  },
  "exclude": ["dist", "playwright-report"]
}
