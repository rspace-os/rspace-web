# RSpace instance to test against
RSPACE_BASE_URL=http://localhost:8080

# Sysadmin account
RSPACE_SYSADMIN_USERNAME=sysadmin1
RSPACE_SYSADMIN_PASSWORD=

# Override test user for API tests (UI tests use appUser from the USERS map)
RSPACE_TEST_USERNAME=user1a
RSPACE_TEST_PASSWORD=user1234

# API key for RSPACE_TEST_USERNAME — get from: Profile → API Key
RSPACE_TEST_API_KEY=

