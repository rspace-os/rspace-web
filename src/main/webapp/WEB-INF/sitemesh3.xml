<sitemesh>
    <!--
      SiteMesh 3 configuration (replaces the SiteMesh 2 sitemesh.xml + decorators.xml).

      NB path matching differs from SiteMesh 2: ConfigurableSiteMeshFilter matches against
      servletPath + pathInfo only, WITHOUT the query string. SiteMesh 2 appended the query
      string to the matched path, so query-string-based excludes (e.g. the old "/*ajax=true*")
      no longer apply and have been dropped; use a path-based exclude instead where needed.
      Decorator names are resolved relative to SiteMesh's default decorator prefix
      (/WEB-INF/decorators/), so they are given as bare file names here. Do NOT prefix them
      with /WEB-INF/decorators/ — that gets prepended again, producing a // empty segment
      that Jetty/Tomcat reject ("Ambiguous URI empty segment").
    -->

    <!-- Paths that must never be decorated (evaluated before the decorator mappings below). -->
    <mapping path="/error.jsp" exclude="true"/>
    <mapping path="*/ajax/*" exclude="true"/>
    <mapping path="/scripts/**" exclude="true"/>
    <mapping path="/ui/dist/**" exclude="true"/>
    <mapping path="/resources/*" exclude="true"/>
    <mapping path="/image/getImage/**" exclude="true"/>
    <mapping path="/image/getImageForEdit/**" exclude="true"/>
    <mapping path="/Streamfile/*" exclude="true"/>
    <mapping path="/public/status" exclude="true"/>
    <mapping path="/public/version" exclude="true"/>
    <mapping path="/public/bannerImageName" exclude="true"/>
    <mapping path="/public/apiDocs" exclude="true"/>
    <mapping path="/slack/callbacks/*" exclude="true"/>
    <mapping path="/msteams/rspaceAuth*" exclude="true"/>
    <mapping path="/officeOnline/*" exclude="true"/>
    <mapping path="/collaboraOnline/*" exclude="true"/>
    <mapping path="/wopi/*" exclude="true"/>
    <mapping path="/oauth/*" exclude="true"/>
    <mapping path="/messaging/get_calendar_event" exclude="true"/>
    <mapping path="/tools/*" exclude="true"/>
    <mapping path="/externalTinymcePlugins/*" exclude="true"/>
    <mapping path="*/public/publishedView/publishedDocuments/*" exclude="true"/>
    <mapping path="/molbiol/*" exclude="true"/>
    <mapping path="/inventory" exclude="true"/>
    <mapping path="/inventory/**" exclude="true"/>
    <mapping path="/listOfMaterials/**" exclude="true"/>
    <mapping path="*/public/inventory/**" exclude="true"/>
    <mapping path="/apps" exclude="true"/>
    <mapping path="/gallery" exclude="true"/>
    <mapping path="/gallery*" exclude="true"/>
    <mapping path="/gallery/**" exclude="true"/>
    <mapping path="/about" exclude="true"/>
    <mapping path="/about/**" exclude="true"/>

    <!-- Public / external pages decorator -->
    <mapping path="*/signup*" decorator="externalPages.jsp"/>
    <mapping path="*/cloud/verifysignup*" decorator="externalPages.jsp"/>
    <mapping path="*/cloud/verifyEmailChange*" decorator="externalPages.jsp"/>
    <mapping path="*/cloud/resendConfirmationEmail*" decorator="externalPages.jsp"/>
    <mapping path="*/login*" decorator="externalPages.jsp"/>
    <mapping path="*/adminLogin*" decorator="externalPages.jsp"/>
    <mapping path="*/passwordReset*" decorator="externalPages.jsp"/>
    <mapping path="*/vfpwd/verificationPasswordResetReply*" decorator="externalPages.jsp"/>
    <mapping path="*/public/*" decorator="externalPages.jsp"/>
    <mapping path="/msteams/*" decorator="externalPages.jsp"/>

    <!-- Default decorator (catch-all) -->
    <mapping decorator="default.jsp"/>
</sitemesh>
